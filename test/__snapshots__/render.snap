=== styling > 1 ===
[data-cellery-cell="Container"]{flex:1 1 auto;padding:0.5rem;color:#00c950;border:1px solid #00c950;display:flex;align-items:center;justify-content:space-between}[data-cellery-cell="Container"]:hover{color:#00d3f2;border:1px solid #00d3f2;cursor:pointer}
=== styling > 2 ===
<div
        data-cellery-cell="Container"
        id="main"
        
      >
        <style>
          #main [data-cellery-cell="Container"]{flex:1 1 auto;padding:0.5rem;color:#00c950;border:1px solid #00c950;display:flex;align-items:center;justify-content:space-between}#main [data-cellery-cell="Container"]:hover{color:#00d3f2;border:1px solid #00d3f2;cursor:pointer}
        </style>
        <span data-cellery-cell="Text" >Hello world!</span><span data-cellery-cell="Text" ></span>
      </div>
=== styles - html > 1 ===
#main{flex:1 1 auto;display:flex;flex-flow:row;padding:1em}
=== styles - html > 2 ===
<div
        data-cellery-cell="Container"
        id="main"
        
      >
        <style>
          
        </style>
        <p data-cellery-cell="Text"  class="text-wrap">Loading...</p>
      </div>
=== styles - html events > 1 ===
[data-cellery-cell="div"]{flex:1 1 auto;padding:0.5rem;color:#00c950;border:1px solid #00c950;display:flex;align-items:center;justify-content:space-between}[data-cellery-cell="div"]:hover{color:#00d3f2;border:1px solid #00d3f2;cursor:pointer}
=== styles - html events > 2 ===
